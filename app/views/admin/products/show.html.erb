<div class="mx-auto md:w-2/3 w-full flex">
  <div class="mx-auto">
    <%= render @admin_product %>

    <%= link_to t('admin.common.edit_this', resource: 'product'), edit_admin_product_path(@admin_product), class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to t('admin.common.back_to', resource: 'products'), admin_products_path, class: "ml-2 rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <div class="inline-block ml-2">
      <%= button_to t('admin.common.destroy_this', resource: 'product'), admin_products_path(@admin_product), method: :delete, class: "mt-2 rounded-lg py-3 px-5 bg-gray-100 font-medium" %>
    </div>
  </div>
</div>
